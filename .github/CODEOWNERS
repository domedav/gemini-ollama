# By default, require reviews from the maintainers for all files.
* @domedav/gemini-ollama-maintainers

# Require reviews from the release approvers for critical files.
# These patterns override the rule above.
/package.json @domedav/gemini-ollama-askmode-approvers
/package-lock.json @domedav/gemini-ollama-askmode-approvers
/GEMINI.md @domedav/gemini-ollama-askmode-approvers
/SECURITY.md @domedav/gemini-ollama-askmode-approvers
/LICENSE @domedav/gemini-ollama-askmode-approvers
/.github/workflows/ @domedav/gemini-ollama-askmode-approvers
/packages/cli/package.json @domedav/gemini-ollama-askmode-approvers
/packages/core/package.json @domedav/gemini-ollama-askmode-approvers

# Docs have a dedicated approver group in addition to maintainers
/docs/ @domedav/gemini-ollama-maintainers @domedav/gemini-ollama-docs
/README.md @domedav/gemini-ollama-maintainers @domedav/gemini-ollama-docs

# Prompt contents, tool definitions, and evals require reviews from prompt approvers
/packages/core/src/prompts/ @domedav/gemini-ollama-prompt-approvers
/packages/core/src/tools/ @domedav/gemini-ollama-prompt-approvers
/evals/ @domedav/gemini-ollama-prompt-approvers
